# Copy this file to `.env` and fill in real values for your machine.
# `.env` is gitignored.

# ---- App ----
APP_ENV=dev          # dev | prod
APP_DEBUG=1          # 1 = show error details, 0 = hide

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=portfolio_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ---- Contact form ----
# Messages are emailed to this address (also used when web3forms is disabled).
CONTACT_NOTIFY_EMAIL=The.Sam.Nolan1998@gmail.com

# Optional: get a free key at https://web3forms.com using the email above.
# Browser-side delivery — required for reliable email on local/dev hosting.
# Leave blank to fall back to PHP mail() instead.
WEB3FORMS_ACCESS_KEY=

# ---- Hidden admin panel ----
# Change this to a long random string only you know.
# Admin URL will be: http://localhost:8000/<ADMIN_PATH>
ADMIN_PATH=samadminpanel
