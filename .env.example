# Copy this file to `.env` and fill in real values for your machine.
# `.env` is gitignored.

# ---- App ----
APP_ENV=dev          # dev | prod
APP_DEBUG=1          # 1 = show error details, 0 = hide

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=portfolio_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ---- Contact form ----
# Optional: get a free key at https://web3forms.com (used to email-forward submissions).
# Leave blank to disable email forwarding (DB-only mode).
WEB3FORMS_ACCESS_KEY=
